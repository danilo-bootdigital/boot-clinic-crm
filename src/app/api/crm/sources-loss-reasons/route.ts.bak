import { NextRequest, NextResponse } from 'next/server';
import { prisma } from '@/lib/db/prisma';
import { CreateDealSourceSchema, CreateDealLossReasonSchema } from '@/lib/validations/crm';
import { getCurrentUser } from '@/lib/auth/server';
import { UserRole } from '@prisma/client';

// GET /api/crm/sources - Listar fontes
export async function GET(request: NextRequest) {
  try {
    const user = await getCurrentUser();
    if (!user) return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });

    const sources = await prisma.dealSource.findMany({
      where: { companyId: user.companyId },
      orderBy: { name: 'asc' },
    });

    return NextResponse.json(sources);
  } catch (error) {
    console.error('Erro ao listar fontes:', error);
    return NextResponse.json({ error: 'Erro interno do servidor' }, { status: 500 });
  }
}

// POST /api/crm/sources - Criar fonte
export async function POST(request: NextRequest) {
  try {
    const user = await getCurrentUser();
    if (!user) return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });

    // Verificar permissão
    if (user.role === UserRole.MARKETING || user.role === UserRole.FINANCE) {
      return NextResponse.json({ error: 'Sem permissão para criar fontes' }, { status: 403 });
    }

    const body = await request.json();
    const validatedData = CreateDealSourceSchema.parse(body);

    // Verificar se já existe
    const existingSource = await prisma.dealSource.findFirst({
      where: {
        name: validatedData.name,
        companyId: user.companyId,
      },
    });

    if (existingSource) {
      return NextResponse.json({ error: 'Fonte já existe' }, { status: 400 });
    }

    const source = await prisma.dealSource.create({
      data: {
        name: validatedData.name,
        companyId: user.companyId,
      },
    });

    return NextResponse.json(source, { status: 201 });
  } catch (error) {
    console.error('Erro ao criar fonte:', error);
    if (error instanceof Error && error.name === 'ZodError') {
      return NextResponse.json({ error: 'Dados inválidos', details: error.message }, { status: 400 });
    }
    return NextResponse.json({ error: 'Erro interno do servidor' }, { status: 500 });
  }
}

// GET /api/crm/loss-reasons - Listar motivos de perda
export async function GET(request: NextRequest) {
  try {
    const user = await getCurrentUser();
    if (!user) return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });

    const lossReasons = await prisma.dealLossReason.findMany({
      where: { companyId: user.companyId },
