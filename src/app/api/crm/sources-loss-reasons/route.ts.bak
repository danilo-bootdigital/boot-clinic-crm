// POST /api/crm/loss-reasons - Criar motivo de perda
export async function POST(request: NextRequest) {
  try {
    const user = await getCurrentUser();
    if (!user) return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });

    // Verificar permissão
    if (user.role === UserRole.MARKETING || user.role === UserRole.FINANCE) {
      return NextResponse.json({ error: 'Sem permissão para criar motivos de perda' }, { status: 403 });
    }

    const body = await request.json();
    const validatedData = CreateDealLossReasonSchema.parse(body);

    // Verificar se já existe
    const existingReason = await prisma.dealLossReason.findFirst({
      where: {
        name: validatedData.name,
        companyId: user.companyId,
      },
    });

    if (existingReason) {
      return NextResponse.json({ error: 'Motivo de perda já existe' }, { status: 400 });
    }

    const lossReason = await prisma.dealLossReason.create({
      data: {
        name: validatedData.name,
        companyId: user.companyId,
      },
    });

    return NextResponse.json(lossReason, { status: 201 });
  } catch (error) {
    console.error('Erro ao criar motivo de perda:', error);
    if (error instanceof Error && error.name === 'ZodError') {
      return NextResponse.json({ error: 'Dados inválidos', details: error.message }, { status: 400 });
    }
    return NextResponse.json({ error: 'Erro interno do servidor' }, { status: 500 });
  }
}