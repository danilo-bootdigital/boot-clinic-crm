import { NextRequest, NextResponse } from 'next/server';
import { prisma } from '@/lib/db/prisma';
import { MarkDealWonSchema, MarkDealLostSchema } from '@/lib/validations/crm';
import { getCurrentUser } from '@/lib/auth/server';
import { UserRole } from '@prisma/client';
import { ActivityType } from '@/lib/validations/crm';

// PATCH /api/crm/deals/[id]/won - Marcar como ganho
export async function PATCH(request: NextRequest, { params }: { params: { id: string } }) {
  try {
    const user = await getCurrentUser();
    if (!user) return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });

    const dealId = params.id;

    // Verificar permissão
    const hasAccess = await checkDealPermission(user.id, dealId);
    if (!hasAccess) {
      return NextResponse.json({ error: 'Sem permissão para marcar como ganho' }, { status: 403 });
    }

    const body = await request.json();
    const validatedData = MarkDealWonSchema.parse(body);

    // Buscar deal atual
    const deal = await prisma.deal.findUnique({
      where: { id: dealId },
      include: {
        stage: true,
        patient: true,
      },
    });

    if (!deal) {
      return NextResponse.json({ error: 'Deal não encontrado' }, { status: 404 });
    }

    // Atualizar deal
    const updatedDeal = await prisma.deal.update({
      where: { id: dealId },
      data: {
        status: 'WON',
        wonAt: new Date(),
      },
      include: {
        pipeline: {
          select: { name: true },
        },
        stage: {
          select: { name: true, color: true },
        },
        patient: {
          select: { name: true, phone: true },
        },
        responsibleUser: {
          select: { name: true },
        },
      },
    });

    // Mover para etapa final de ganho
    const wonStage = await prisma.pipelineStage.findFirst({
      where: {
        pipelineId: deal.pipelineId,
        finalType: 'WON',
      },
    });

    if (wonStage) {
      await prisma.deal.update({
        where: { id: dealId },
        data: { stageId: wonStage.id },
      });
    }

    // Registrar atividade
    await prisma.dealActivity.create({
      data: {
        type: ActivityType.WON,
        title: 'Deal ganho',
        description: validatedData.notes || `Deal "${updatedDeal.title}" foi marcado como ganho por ${user.name}`,
        companyId: user.companyId,
        dealId: dealId,
        authorId: user.id,
      },
    });

    // Se estiver vinculado a um paciente, registrar na timeline
    if (deal.patientId) {
      await prisma.patientTimelineEvent.create({
        data: {
          patientId: deal.patientId,
          type: 'CRM_WON',
          title: 'Oportunidade ganha',
          content: `Oportunidade "${updatedDeal.title}" foi ganha`,
          authorId: user.id,
        },
      });
    }

    // Registrar auditoria
    await prisma.auditLog.create({
      data: {
        action: 'UPDATE',
        entity: 'Deal',
        entityId: dealId,
        changes: JSON.stringify({ status: 'WON', wonAt: new Date() }),
        userId: user.id,
      },
    });

    return NextResponse.json(updatedDeal);
  } catch (error) {
    console.error('Erro ao marcar como ganho:', error);
    if (error instanceof Error && error.name === 'ZodError') {
      return NextResponse.json({ error: 'Dados inválidos', details: error.message }, { status: 400 });
    }
    return NextResponse.json({ error: 'Erro interno do servidor' }, { status: 500 });
  }
}

// PATCH /api/crm/deals/[id]/lost - Marcar como perdido
export async function PATCH(request: NextRequest, { params }: { params: { id: string } }) {
  try {
    const user = await getCurrentUser();
    if (!user) return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });

    const dealId = params.id;

    // Verificar permissão
    const hasAccess = await checkDealPermission(user.id, dealId);
    if (!hasAccess) {
      return NextResponse.json({ error: 'Sem permissão para marcar como perdido' }, { status: 403 });
    }

    const body = await request.json();
    const validatedData = MarkDealLostSchema.parse(body);

    // Buscar deal atual
    const deal = await prisma.deal.findUnique({
      where: { id: dealId },
      include: {
        stage: true,
        patient: true,
        lossReason: true,
      },
    });

    if (!deal) {
      return NextResponse.json({ error: 'Deal não encontrado' }, { status: 404 });
    }

    // Atualizar deal
    const updatedDeal = await prisma.deal.update({
      where: { id: dealId },
      data: {
        status: 'LOST',
        lostAt: new Date(),
        lossReasonId: validatedData.lossReasonId,
      },
      include: {
        pipeline: {
          select: { name: true },
        },
        stage: {
          select: { name: true, color: true },
        },
        patient: {
          select: { name: true, phone: true },
        },
        responsibleUser: {
          select: { name: true },
        },
        lossReason: {
          select: { name: true },
        },
      },
    });

    // Mover para etapa final de perda
    const lostStage = await prisma.pipelineStage.findFirst({
      where: {
        pipelineId: deal.pipelineId,
        finalType: 'LOST',
      },
    });

    if (lostStage) {
      await prisma.deal.update({
        where: { id: dealId },
        data: { stageId: lostStage.id },
      });
    }

    // Registrar atividade
    await prisma.dealActivity.create({
      data: {
        type: ActivityType.LOST,
        title: 'Deal perdido',
        description: validatedData.notes || `Deal "${updatedDeal.title}" foi marcado como perdido por ${user.name}`,
        companyId: user.companyId,
        dealId: dealId,
        authorId: user.id,
      },
    });

    // Se estiver vinculado a um paciente, registrar na timeline
    if (deal.patientId) {
      await prisma.patientTimelineEvent.create({
        data: {
          patientId: deal.patientId,
          type: 'CRM_LOST',
          title: 'Oportunidade perdida',
          content: `Oportunidade "${updatedDeal.title}" foi perdida. Motivo: ${updatedDeal.lossReason?.name}`,
          authorId: user.id,
        },
      });
    }

    // Registrar auditoria
    await prisma.auditLog.create({
      data: {
        action: 'UPDATE',
        entity: 'Deal',
        entityId: dealId,
        changes: JSON.stringify({
          status: 'LOST',
          lostAt: new Date(),
          lossReasonId: validatedData.lossReasonId
        }),
        userId: user.id,
      },
    });

    return NextResponse.json(updatedDeal);
  } catch (error) {
    console.error('Erro ao marcar como perdido:', error);
    if (error instanceof Error && error.name === 'ZodError') {
      return NextResponse.json({ error: 'Dados inválidos', details: error.message }, { status: 400 });
    }
    return NextResponse.json({ error: 'Erro interno do servidor' }, { status: 500 });
  }
}

// Helper function
async function checkDealPermission(userId: string, dealId: string) {
  const user = await prisma.user.findUnique({
    where: { id: userId },
    include: { clinic: true },
  });

  if (!user) throw new Error('Usuário não encontrado');

  if (user.role === UserRole.SUPER_ADMIN) return true;

  const deal = await prisma.deal.findUnique({
    where: { id: dealId },
    select: { clinicId: true, responsibleUserId: true },
  });

  if (!deal) throw new Error('Deal não encontrado');

  if (user.clinicId !== deal.clinicId) return false;

  if ([UserRole.RECEPTION, UserRole.ATTENDANCE, UserRole.MANAGER].includes(user.role)) {
    return true;
  }

  if (user.role === UserRole.DOCTOR) {
    const appointment = await prisma.appointment.findFirst({
      where: {
        patientId: deal.patientId,
        professionalId: user.id,
      },
    });
    return !!appointment;
  }

  if (user.role === UserRole.FINANCE) {
    return false;
  }

  if (user.role === UserRole.MARKETING) {
    return false;
  }

  return user.id === deal.responsibleUserId;
}