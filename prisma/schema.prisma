// =====================================================================
// CONTROLE SaaS MODULAR (3 níveis): plano contratado → módulo ativo na
// clínica → permissão do usuário (RBAC). Tudo aditivo e backward-compatible:
// sem linhas configuradas, todo módulo é considerado habilitado.
// =====================================================================

// Catálogo de módulos existentes no sistema (fonte de verdade no banco).
// `isCore` = sempre habilitado (não desligável, evita lockout). `available`
// = módulo já construído (false = preparado para o futuro, ex.: Telemedicina).
model Module {
  id        String   @id @default(cuid())
  key       String   @unique // 'patients','clinico','telemedicina',...
  label     String
  isCore    Boolean  @default(false)
  available Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}

// Nível Clínica: ativação interna de um módulo para uma clínica.
// Ausência de linha = habilitado (default). Permite ligar/desligar por clínica.
model CompanyModule {
  id        String   @id @default(cuid())
  companyId String
  moduleKey String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, moduleKey])
  @@map("company_modules")
}

// Nível SaaS: mapa plano → módulos contratados. Se NÃO houver nenhuma linha
// para um plano, considera-se que o plano contrata todos (backward-compat).
model PlanFeature {
  id        String   @id @default(cuid())
  plan      String // 'trial' | 'basic' | 'pro'
  moduleKey String
  createdAt DateTime @default(now())

  @@unique([plan, moduleKey])
  @@map("plan_features")
}

// ============================================================================
// MÓDULO TELEMEDICINA — centro operacional de atendimento remoto.
// Toda teleconsulta NASCE da Agenda (Appointment.modality = TELEMEDICINA) e
// vincula-se ao paciente. Segue o padrão da base: FK escalar + companyId,
// enriquecimento manual (sem @relation cruzando módulos). Multi-tenant por
// companyId; auditoria via AuditLog (EntityType.TELECONSULTATION).
// ============================================================================

// Sessão de teleconsulta — entidade núcleo (1:1 com o Appointment de origem).
model TelemedicineSession {
  id              String             @id @default(cuid())
  companyId       String
  appointmentId   String             @unique // nasce da agenda
  patientId       String
  professionalId  String
  createdById     String
  status          TelemedicineStatus @default(AGENDADA)
  scheduledAt     DateTime // espelho de Appointment.startAt p/ consultas/KPIs
  // Marcos do atendimento (alimentam duração média / comparecimento no dashboard).
  patientJoinedAt DateTime?
  doctorJoinedAt  DateTime?
  startedAt       DateTime?
  pausedAt        DateTime?
  endedAt         DateTime?
  durationSeconds Int? // calculado no encerramento (startedAt → endedAt)
  noShowAt        DateTime?
  canceledAt      DateTime?
  cancelReason    String?
  // Registro clínico gerado ao encerrar (gancho com Prontuário).
  medicalRecordId String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  room         TelemedicineRoom?
  participants TelemedicineParticipant[]
  chat         TelemedicineChat[]
  attachments  TelemedicineAttachment[]
  consents     TelemedicineConsent[]
  events       TelemedicineAuditLog[]

  @@index([companyId, status])
  @@index([companyId, scheduledAt])
  @@map("telemedicine_sessions")
}

// Sala de vídeo. Provider-agnóstico: por padrão geramos uma URL de sala
// (Jitsi por URL, zero-dependência). roomKey é único e imprevisível.
model TelemedicineRoom {
  id         String               @id @default(cuid())
  companyId  String
  sessionId  String               @unique
  provider   TelemedicineProvider @default(JITSI)
  roomKey    String               @unique // identificador opaco da sala
  roomUrl    String // URL completa da sala (médico entra autenticado)
  publicSlug String               @unique // slug do link público do paciente (/tele/[slug])
  isActive   Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("telemedicine_rooms")
}

// Participante da sala (paciente, médico, convidado). O paciente acessa por
// link público com token temporário; o médico acessa autenticado pelo CRM.
model TelemedicineParticipant {
  id             String          @id @default(cuid())
  companyId      String
  sessionId      String
  role           ParticipantRole
  userId         String? // preenchido p/ médico/staff (User)
  displayName    String
  token          String          @unique // token de acesso à sala (paciente)
  tokenExpiresAt DateTime
  joinedAt       DateTime?
  leftAt         DateTime?
  lastSeenAt     DateTime?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("telemedicine_participants")
}

// Consentimento LGPD do paciente (aceite de teleatendimento). Guarda data/hora,
// IP, user-agent e o texto aceito (snapshot) para rastreabilidade.
model TelemedicineConsent {
  id          String    @id @default(cuid())
  companyId   String
  sessionId   String
  patientId   String
  consentText String // snapshot do termo aceito
  accepted    Boolean   @default(false)
  acceptedAt  DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("telemedicine_consents")
}

// Mensagem de chat durante a consulta (texto ou anexo). Vinculada ao paciente.
model TelemedicineChat {
  id           String          @id @default(cuid())
  companyId    String
  sessionId    String
  patientId    String
  senderRole   ParticipantRole
  senderName   String
  senderUserId String?
  body         String? // texto da mensagem
  attachmentId String? // TelemedicineAttachment quando a mensagem é arquivo
  createdAt    DateTime        @default(now())

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("telemedicine_chat")
}

// Anexo/imagem/documento da teleconsulta. Vinculado à sessão E ao paciente —
// uploads antes/durante/depois. path no storage clínico (signed URL na leitura).
model TelemedicineAttachment {
  id           String                         @id @default(cuid())
  companyId    String
  sessionId    String
  patientId    String
  category     TelemedicineAttachmentCategory @default(OTHER)
  title        String
  originalName String
  url          String // path no storage
  mimeType     String
  size         Int
  phase        TelemedicineAttachmentPhase    @default(DURING) // antes/durante/após
  uploadedBy   String
  createdAt    DateTime                       @default(now())
  deletedAt    DateTime?

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("telemedicine_attachments")
}

// Trilha de eventos da sala (entrada/saída/anexo/encerramento). Complementa o
// AuditLog global com granularidade de sala (timeline da teleconsulta).
model TelemedicineAuditLog {
  id        String   @id @default(cuid())
  companyId String
  sessionId String
  event     String // 'PATIENT_JOINED','DOCTOR_JOINED','STARTED','PAUSED','ENDED'...
  actorRole String? // ParticipantRole/UserRole textual
  actorId   String?
  actorName String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("telemedicine_audit_logs")
}

enum TelemedicineStatus {
  AGENDADA
  AGUARDANDO_PACIENTE
  PACIENTE_ENTROU
  MEDICO_ENTROU
  EM_ATENDIMENTO
  PAUSADA
  FINALIZADA
  CANCELADA
  NAO_COMPARECEU
}

enum TelemedicineProvider {
  JITSI
  DAILY
  TWILIO
  CUSTOM
}

enum ParticipantRole {
  PATIENT
  DOCTOR
  GUEST
}

enum TelemedicineAttachmentCategory {
  EXAM // exames
  REPORT // laudos
  CLINICAL_PHOTO // fotos clínicas
  DOCUMENT // documentos
  CONTRACT // contratos
  OTHER
}

enum TelemedicineAttachmentPhase {
  BEFORE
  DURING
  AFTER
}

// ============================================================================
// MÓDULO FINANCEIRO — FASE 1: CONTAS A RECEBER
// Camada de liquidação sobre entidades existentes. NÃO recria paciente/orçamento:
// a Receita NASCE de um Orçamento aprovado (ClinicalQuote APPROVED) e/ou Contrato
// assinado (PatientContract SIGNED) — referência por FK ESCALAR (padrão Deal/
// Appointment), sem @relation cruzando módulos. Dinheiro em Decimal(12,2) (NUNCA
// Float). Multi-tenant por companyId + RLS no Postgres (FORCE + GUC app.company_id).
// Auditoria via AuditLog (EntityType.RECEIVABLE/...). "Vencido" é DERIVADO na
// leitura (dueDate < now e status PENDENTE/PARCIAL), não é status persistido.
// ============================================================================

// Categoria de receita por clínica (customizável; defaults auto-semeados).
model RevenueCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isDefault Boolean  @default(false) // semeada pelo sistema
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receivables Receivable[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("financial_revenue_categories")
}

// Conta a receber (cabeçalho da receita). Origem escalar: paciente (obrigatório)
// + orçamento/contrato/deal (opcionais, p/ rastreabilidade e anti-duplicação).
model Receivable {
  id                String           @id @default(cuid())
  companyId         String
  patientId         String // origem obrigatória (escalar)
  quoteId           String? // ClinicalQuote APPROVED (origem)
  contractId        String? // PatientContract SIGNED (origem)
  dealId            String? // rastreio comercial (origem Fase 7)
  categoryId        String?
  description       String
  originalAmount    Decimal          @db.Decimal(12, 2)
  discountAmount    Decimal          @default(0) @db.Decimal(12, 2)
  finalAmount       Decimal          @db.Decimal(12, 2) // = original - desconto
  installmentsCount Int              @default(1) // 1 = à vista
  status            ReceivableStatus @default(PENDENTE)
  issueDate         DateTime         @default(now()) // competência/emissão
  notes             String?
  createdById       String
  canceledAt        DateTime?
  canceledReason    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  category     RevenueCategory?        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  installments ReceivableInstallment[]

  @@index([companyId, status])
  @@index([companyId, patientId])
  @@index([companyId, issueDate])
  @@map("financial_receivables")
}

// Parcela de uma conta a receber. À vista = 1 parcela. Σ amount = Receivable.finalAmount.
model ReceivableInstallment {
  id           String            @id @default(cuid())
  companyId    String // denormalizado p/ RLS + escopo
  receivableId String
  number       Int // 1..N
  amount       Decimal           @db.Decimal(12, 2)
  dueDate      DateTime // vencimento
  paidAmount   Decimal           @default(0) @db.Decimal(12, 2) // soma das baixas
  status       InstallmentStatus @default(PENDENTE)
  paidAt       DateTime? // quando quitada totalmente
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  receivable Receivable           @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  payments   InstallmentPayment[]

  @@unique([receivableId, number])
  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@map("financial_installments")
}

// Baixa (pagamento recebido) de uma parcela. Estorno via reversedAt (não deleta —
// rastreabilidade financeira não apaga lançamento). paidAt alimenta o fluxo de caixa.
model InstallmentPayment {
  id            String        @id @default(cuid())
  companyId     String
  installmentId String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  paidAt        DateTime      @default(now()) // data efetiva do pagamento
  notes         String?
  createdById   String
  reversedAt    DateTime? // estorno
  reversedById  String?
  reverseReason String?
  createdAt     DateTime      @default(now())

  installment ReceivableInstallment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@index([companyId, paidAt])
  @@index([installmentId])
  @@map("financial_payments")
}

enum ReceivableStatus {
  PENDENTE
  PARCIAL
  PAGO
  CANCELADO
}

enum InstallmentStatus {
  PENDENTE
  PARCIAL
  PAGO
  CANCELADO
}

// Rótulo MANUAL de como o paciente pagou (sem integração/cobrança real).
enum PaymentMethod {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  TRANSFERENCIA
  BOLETO
  CHEQUE
  OUTRO
}

// ============================================================================
// MÓDULO FINANCEIRO — FASE 2: CONTAS A PAGAR
// Simétrico aos recebíveis (mesma infra: companyId + RLS FORCE+GUC, Decimal(12,2),
// withFinanceTenant, writeAudit). Despesa nasce de um Fornecedor (opcional) e tem
// categoria + centro de custo. PayablePayment espelha InstallmentPayment p/ unificar
// Fluxo de Caixa (Fase 5) e DRE (Fase 11) SEM retrabalho. `professionalId` é o gancho
// do Repasse Médico (Fase 8). "Vencido" derivado (dueDate < now). Lições da Fase 1
// já incorporadas: valor coerente, lock na baixa, cancelar só sem pagamento.
// ============================================================================

// Fornecedor (entidade nova — não existia). Reusada por Contas a Pagar.
model Supplier {
  id        String    @id @default(cuid())
  companyId String
  name      String
  document  String? // CNPJ/CPF (opcional)
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  payables Payable[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("financial_suppliers")
}

// Categoria de despesa por clínica (espelho de RevenueCategory; defaults semeados).
model ExpenseCategory {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payables Payable[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("financial_expense_categories")
}

// Centro de custo (Fase 4 antecipada — Payable referencia; defaults semeados).
model CostCenter {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payables Payable[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("financial_cost_centers")
}

// Conta a pagar (despesa). Baixa via PayablePayment (parcial/total + estorno).
model Payable {
  id             String        @id @default(cuid())
  companyId      String
  supplierId     String?
  categoryId     String? // ExpenseCategory
  costCenterId   String?
  professionalId String? // gancho de Repasse Médico (Fase 8) — escalar, sem @relation
  description    String
  originalAmount Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  finalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2) // soma das baixas não estornadas
  status         PayableStatus @default(PENDENTE)
  issueDate      DateTime      @default(now())
  dueDate        DateTime // vencimento
  notes          String?
  createdById    String
  canceledAt     DateTime?
  canceledReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  supplier   Supplier?        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  costCenter CostCenter?      @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  payments   PayablePayment[]

  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@index([companyId, supplierId])
  @@map("financial_payables")
}

// Baixa (pagamento de saída) — idêntico a InstallmentPayment p/ unificar o fluxo de caixa.
model PayablePayment {
  id            String        @id @default(cuid())
  companyId     String
  payableId     String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  paidAt        DateTime      @default(now())
  notes         String?
  createdById   String
  reversedAt    DateTime?
  reversedById  String?
  reverseReason String?
  createdAt     DateTime      @default(now())

  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@index([companyId, paidAt])
  @@index([payableId])
  @@map("financial_payable_payments")
}

enum PayableStatus {
  PENDENTE
  PARCIAL
  PAGO
  CANCELADO
}
