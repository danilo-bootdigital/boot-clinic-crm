generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multiempresa (cada Company = 1 clínica assinante do SaaS)
model Company {
  id                  String        @id @default(cuid())
  name                String
  cnpj                String?       @unique
  logo                String?
  address             String?
  phone               String?
  email               String?
  // Assinatura SaaS — gerida pelo painel Super-Admin.
  status              CompanyStatus @default(ACTIVE)
  plan                String? // "trial" | "basic" | "pro"
  trialEndsAt         DateTime?
  // Integração Asaas (cobrança recorrente no cartão). Preenchidos para planos pagos.
  asaasCustomerId     String?
  asaasSubscriptionId String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  // Relacionamentos
  users    User[]
  patients Patient[]
  tags     Tag[]

  @@map("companies")
}

// Situação da assinatura de uma clínica no SaaS.
enum CompanyStatus {
  ACTIVE // assinatura ativa
  TRIAL // em período de teste
  SUSPENDED // acesso bloqueado (ex.: inadimplência) — usuários não-super recebem 403
  CANCELED // assinatura encerrada
}

// Usuários e Autenticação
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  avatar      String?
  role        UserRole
  companyId   String
  // Permissões por módulo: { patients|crm|agenda|followup|dashboard|configuracoes: 'none'|'view'|'edit' }
  permissions Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company         Company         @relation(fields: [companyId], references: [id])
  createdPatients Patient[] // Pacientes criados por este usuário
  timelineEvents  TimelineEvent[] // Eventos de timeline criados por este usuário

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  DOCTOR
  RECEPTION
  FINANCE
  MARKETING
  ATTENDANCE
}

// Módulo de Pacientes - BOOT CLINIC CRM
model Patient {
  id              String        @id @default(cuid())
  name            String
  cpf             String
  birthDate       DateTime
  gender          Gender
  phone           String
  whatsapp        String?
  email           String?
  origin          PatientOrigin
  status          PatientStatus @default(ACTIVE)
  // Endereço e convênio
  address         String?
  city            String?
  state           String?
  zipCode         String?
  insurance       String? // convênio
  insuranceNumber String? // número da carteirinha
  notes           String? // observações
  companyId       String
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company     Company             @relation(fields: [companyId], references: [id])
  createdBy   User                @relation(fields: [createdById], references: [id])
  timeline    TimelineEvent[]
  attachments PatientAttachment[]
  tags        PatientTag[]

  // CPF é único POR EMPRESA (não global): a mesma pessoa pode ser paciente de
  // várias clínicas. (Reuso de CPF de paciente arquivado segue como dívida
  // conhecida — exigiria índice único parcial WHERE deleted_at IS NULL.)
  @@unique([companyId, cpf])
  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum PatientOrigin {
  GOOGLE
  FACEBOOK
  INSTAGRAM
  REFERRAL
  WALK_IN
  PHONE
  WHATSAPP
  OTHER
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// Timeline de Pacientes
model TimelineEvent {
  id        String            @id @default(cuid())
  title     String
  content   String
  type      TimelineEventType
  patientId String
  userId    String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Relacionamentos
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("timeline_events")
}

enum TimelineEventType {
  NOTE
  APPOINTMENT
  PHONE_CALL
  EMAIL
  WHATSAPP
  DOCUMENT
  STATUS_CHANGE
}

// Anexos de Pacientes
model PatientAttachment {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  patientId    String
  uploadedBy   String
  createdAt    DateTime @default(now())

  // Relacionamentos
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_attachments")
}

// Tags de Pacientes
model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3B82F6")
  companyId String
  createdAt DateTime @default(now())

  // Relacionamentos
  company  Company      @relation(fields: [companyId], references: [id])
  patients PatientTag[]

  // Único por empresa (não global) — cada clínica tem suas próprias tags.
  @@unique([companyId, name])
  @@map("tags")
}

model PatientTag {
  id        String   @id @default(cuid())
  patientId String
  tagId     String
  createdAt DateTime @default(now())

  // Relacionamentos
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([patientId, tagId])
  @@map("patient_tags")
}

// Módulo de CRM/Pipeline
model Pipeline {
  id          String         @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean        @default(false)
  status      PipelineStatus @default(ACTIVE)
  order       Int            @default(0)
  companyId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@map("pipelines")
}

model PipelineStage {
  id          String    @id @default(cuid())
  name        String
  order       Int
  color       String    @default("#3B82F6")
  probability Int?
  isFinal     Boolean   @default(false)
  finalType   FinalType @default(NONE)
  pipelineId  String
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pipeline_stages")
}

model DealLossReason {
  id        String   @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime @default(now())

  @@map("deal_loss_reasons")
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  description       String?
  valueEstimated    Float?
  priority          Priority   @default(MEDIUM)
  status            DealStatus @default(NEW)
  source            DealSource @default(OTHER)
  companyId         String
  pipelineId        String?
  stageId           String?
  patientId         String?
  responsibleUserId String
  lossReasonId      String?
  nextFollowUpAt    DateTime?
  lastContactAt     DateTime?
  wonAt             DateTime?
  lostAt            DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  @@map("deals")
}

model DealActivity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  companyId   String
  dealId      String
  authorId    String
  createdAt   DateTime     @default(now())

  @@map("deal_activities")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DealStatus {
  NEW
  CONTACTED
  IN_NEGOTIATION
  APPOINTMENT_SCHEDULED
  APPOINTMENT_ATTENDED
  QUOTE_SENT
  WON
  LOST
}

enum PipelineStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum FinalType {
  WON
  LOST
  NONE
}

enum DealSource {
  WEBSITE
  REFERRAL
  PHONE
  WHATSAPP
  SOCIAL_MEDIA
  WALK_IN
  EMAIL
  OTHER
}

enum ActivityType {
  CREATED
  MOVED_STAGE
  FOLLOW_UP_CREATED
  FOLLOW_UP_COMPLETED
  NOTE_ADDED
  TASK_CREATED
  TASK_COMPLETED
  WON
  LOST
}

// Módulo de Follow-up e Automações
model FollowUpTemplate {
  id              String          @id @default(cuid())
  name            String
  description     String?
  content         String
  type            FollowUpType
  dueHours        Int // Horas após o gatilho
  isRecurring     Boolean         @default(false)
  recurrenceType  RecurrenceType?
  recurrenceEvery Int? // Dias/semanas/meses
  isActive        Boolean         @default(true)
  companyId       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@unique([companyId, name])
  @@map("follow_up_templates")
}

model FollowUpTask {
  id             String     @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime
  status         TaskStatus @default(PENDING)
  priority       Priority   @default(MEDIUM)
  type           TaskType
  templateId     String?
  assignedToId   String?
  createdById    String
  completedAt    DateTime?
  canceledAt     DateTime?
  canceledReason String?
  companyId      String
  patientId      String?
  dealId         String?
  appointmentId  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  @@map("follow_up_tasks")
}

model AutomationRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@map("automation_rules")
}

model AutomationTrigger {
  id         String     @id @default(cuid())
  ruleId     String
  entityType EntityType
  event      String // Evento específico (paciente.criado, pipeline.movido, etc.)
  condition  String? // Condição JSON para execução
  companyId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  @@unique([companyId, ruleId, entityType, event])
  @@map("automation_triggers")
}

model AutomationAction {
  id         String     @id @default(cuid())
  ruleId     String
  actionType ActionType
  config     String // Configuração JSON da ação
  order      Int
  companyId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?

  @@unique([companyId, ruleId, order])
  @@map("automation_actions")
}

model AutomationExecution {
  id          String          @id @default(cuid())
  ruleId      String
  triggerId   String
  status      ExecutionStatus @default(PENDING)
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  error       String?
  result      String? // Resultado JSON
  companyId   String
  patientId   String?
  dealId      String?
  taskId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@map("automation_executions")
}

model NotificationEvent {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  priority  Priority         @default(MEDIUM)
  isRead    Boolean          @default(false)
  userId    String
  companyId String
  patientId String?
  dealId    String?
  metadata  String? // Dados adicionais JSON
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@map("notification_events")
}

// Módulo de WhatsApp (estrutura interna; envio real via Evolution API quando configurada)
model WhatsAppConversation {
  id            String    @id @default(cuid())
  companyId     String
  patientId     String?
  contactName   String
  contactPhone  String
  status        String    @default("OPEN") // OPEN | CLOSED
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             String   @id @default(cuid())
  companyId      String
  conversationId String
  content        String
  direction      String // INCOMING | OUTGOING
  status         String   @default("PENDING") // PENDING | SENT | FAILED | RECEIVED
  createdAt      DateTime @default(now())

  @@map("whatsapp_messages")
}

model WhatsAppQuickReply {
  id        String    @id @default(cuid())
  companyId String
  title     String
  content   String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@map("whatsapp_quick_replies")
}

// Preferências de notificação por empresa
model NotificationSetting {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  emailEnabled         Boolean  @default(true)
  smsEnabled           Boolean  @default(false)
  whatsappEnabled      Boolean  @default(false)
  appointmentReminders Boolean  @default(true)
  followUpReminders    Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("notification_settings")
}

// Módulo de Agenda Médica
model Appointment {
  id                 String              @id @default(cuid())
  patientId          String
  professionalId     String
  specialtyId        String
  type               String
  status             AppointmentStatus   @default(PENDING)
  startAt            DateTime
  endAt              DateTime
  durationMinutes    Int
  source             String
  notes              String?
  createdById        String
  confirmedAt        DateTime?
  canceledAt         DateTime?
  cancellationReason String?
  noShowAt           DateTime?
  attendedAt         DateTime?
  companyId          String
  dealId             String?
  // Telemedicina (aditivo, nulável): modalidade da consulta + atalho p/ a sala.
  // PRESENCIAL é o default — backward-compatible com consultas existentes.
  modality           AppointmentModality @default(PRESENCIAL)
  roomUrl            String? // URL da sala (espelho de TelemedicineRoom.roomUrl)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@map("appointments")
}

enum AppointmentModality {
  PRESENCIAL
  TELEMEDICINA
}

model Specialty {
  id          String    @id @default(cuid())
  name        String
  description String?
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@map("specialties")
}

model Professional {
  id        String    @id @default(cuid())
  name      String
  crm       String?
  phone     String?
  email     String?
  companyId String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("professionals")
}

model ProfessionalSpecialty {
  id             String   @id @default(cuid())
  professionalId String
  specialtyId    String
  companyId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([professionalId, specialtyId])
  @@map("professional_specialties")
}

model Room {
  id          String    @id @default(cuid())
  name        String
  description String?
  companyId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@map("rooms")
}

model AppointmentType {
  id          String    @id @default(cuid())
  name        String
  description String?
  duration    Int // minutos
  companyId   String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@map("appointment_types")
}

model ProfessionalSchedule {
  id             String    @id @default(cuid())
  professionalId String
  dayOfWeek      Int // 0-6 (Domingo-Sábado)
  startTime      String // HH:mm
  endTime        String // HH:mm
  isActive       Boolean   @default(true)
  companyId      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@map("professional_schedules")
}

model ScheduleBlock {
  id               String    @id @default(cuid())
  professionalId   String
  date             DateTime
  startTime        String // HH:mm
  endTime          String // HH:mm
  reason           String?
  isRecurring      Boolean   @default(false)
  recurringPattern String? // daily, weekly, monthly
  companyId        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@map("schedule_blocks")
}

model AppointmentStatusHistory {
  id            String            @id @default(cuid())
  appointmentId String
  status        AppointmentStatus
  notes         String?
  changedById   String
  createdAt     DateTime          @default(now())

  @@map("appointment_status_history")
}

model AppointmentReminder {
  id            String       @id @default(cuid())
  appointmentId String
  type          ReminderType
  sentAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("appointment_reminders")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  RESCHEDULED
  ATTENDED
  NO_SHOW
}

enum ReminderType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

// Enums
enum FollowUpType {
  MANUAL
  AUTOMATIC
  RECURRING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
  OVERDUE
}

enum TaskType {
  FOLLOW_UP
  REMINDER
  ALERT
  TASK
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum EntityType {
  PATIENT
  DEAL
  APPOINTMENT
  WHATSAPP_CONVERSATION
  // Módulo Clínico Documental
  ANAMNESIS
  MEDICAL_RECORD
  CONTRACT
  QUOTE
  PATIENT_IMAGE
  PATIENT_DOCUMENT
  // Módulo Telemedicina
  TELECONSULTATION
  TELEMEDICINE_ROOM
  TELEMEDICINE_CONSENT
  TELEMEDICINE_ATTACHMENT
  // Módulo Financeiro — Contas a Receber (Fase 1)
  RECEIVABLE
  RECEIVABLE_INSTALLMENT
  INSTALLMENT_PAYMENT
  REVENUE_CATEGORY
  // Módulo Financeiro — Contas a Pagar (Fase 2)
  PAYABLE
  PAYABLE_PAYMENT
  SUPPLIER
  EXPENSE_CATEGORY
  COST_CENTER
}

enum ActionType {
  CREATE_TASK
  CREATE_FOLLOW_UP
  MOVE_PIPELINE_STAGE
  SEND_NOTIFICATION
  SEND_WHATSAPP
  CREATE_TIMELINE_EVENT
  ASSIGN_USER
  UPDATE_STATUS
  // Ações genéricas de auditoria (CRUD)
  CREATE
  UPDATE
  ARCHIVE
  RESTORE
  UPLOAD_ATTACHMENT
  DELETE_ATTACHMENT
  ADD_TAG
  REMOVE_TAG
  // Operações financeiras (Fase 1)
  SETTLE // baixa de pagamento
  CANCEL // cancelamento (receita/parcela)
  REVERSE // estorno de pagamento
  DELETE // exclusão definitiva (ex.: categoria financeira não usada)
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

// Sistema de Auditoria
model AuditLog {
  id         String     @id @default(cuid())
  userId     String?
  userName   String?
  action     ActionType
  entityType EntityType
  entityId   String
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime   @default(now())
  companyId  String

  @@map("audit_logs")
}

// =====================================================================
// MÓDULO CLÍNICO DOCUMENTAL
// Anamnese · Prontuário · Contratos · Orçamentos · Imagens/Anexos.
// Escopo multiempresa (companyId) e vínculo ao paciente (patientId).
// Sem prescrição, CID, TISS ou IA médica — apenas documental/operacional.
// FKs por escalar (companyId/patientId) seguindo o padrão de Deal/Appointment.
// =====================================================================

// ---- ANAMNESE DIGITAL ----

// Modelo de anamnese por especialidade (catálogo da clínica).
model AnamnesisTemplate {
  id          String    @id @default(cuid())
  name        String
  specialty   String? // especialidade alvo (texto livre)
  description String?
  isActive    Boolean   @default(true)
  companyId   String
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  questions AnamnesisQuestion[]

  @@map("anamnesis_templates")
}

// Pergunta personalizável de um modelo de anamnese.
model AnamnesisQuestion {
  id         String                @id @default(cuid())
  templateId String
  companyId  String
  label      String
  type       AnamnesisQuestionType @default(TEXT)
  options    Json? // alternativas para MULTIPLE_CHOICE/SINGLE_CHOICE
  required   Boolean               @default(false)
  order      Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  template AnamnesisTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("anamnesis_questions")
}

// Anamnese preenchida para um paciente.
model PatientAnamnesis {
  id                 String          @id @default(cuid())
  companyId          String
  patientId          String
  templateId         String?
  // Anamnese pré-consulta vinculada a uma teleconsulta / consulta (opcional).
  appointmentId      String?
  teleconsultationId String?
  title              String
  status             AnamnesisStatus @default(DRAFT)
  createdById        String
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  answers PatientAnamnesisAnswer[]

  @@map("patient_anamneses")
}

// Resposta de uma pergunta dentro de uma anamnese preenchida.
model PatientAnamnesisAnswer {
  id          String   @id @default(cuid())
  companyId   String
  anamnesisId String
  questionId  String?
  label       String // rótulo da pergunta (snapshot)
  value       String? // resposta em texto (ou opção escolhida / sim-não)
  fileUrl     String? // path no storage quando a resposta é upload
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  anamnesis PatientAnamnesis @relation(fields: [anamnesisId], references: [id], onDelete: Cascade)

  @@map("patient_anamnesis_answers")
}

// ---- PRONTUÁRIO OPERACIONAL ----

// Registro de prontuário (evolução, observação, histórico). NÃO é prontuário
// médico avançado: sem prescrição/CID/TISS.
model MedicalRecord {
  id                 String            @id @default(cuid())
  companyId          String
  patientId          String
  type               MedicalRecordType @default(EVOLUTION)
  title              String
  content            String
  professionalId     String? // profissional responsável pelo registro (Professional)
  // Registro nascido de uma consulta/teleconsulta (opcional, aditivo).
  appointmentId      String?
  teleconsultationId String?
  createdById        String // usuário que registrou
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  attachments MedicalRecordAttachment[]

  @@map("medical_records")
}

model MedicalRecordAttachment {
  id           String   @id @default(cuid())
  companyId    String
  recordId     String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String // path no storage (signed URL na leitura)
  uploadedBy   String
  createdAt    DateTime @default(now())

  record MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("medical_record_attachments")
}

// ---- CONTRATOS PERSONALIZÁVEIS ----

// Modelo de contrato com variáveis dinâmicas no corpo (ex.: {{nome_paciente}}).
model ContractTemplate {
  id          String    @id @default(cuid())
  name        String
  description String?
  content     String // corpo com variáveis {{...}}
  isActive    Boolean   @default(true)
  companyId   String
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("contract_templates")
}

// Contrato gerado para um paciente (conteúdo já com variáveis resolvidas).
model PatientContract {
  id          String         @id @default(cuid())
  companyId   String
  patientId   String
  templateId  String?
  title       String
  content     String
  variables   Json? // snapshot das variáveis usadas
  value       Float?
  status      ContractStatus @default(DRAFT)
  createdById String
  sentAt      DateTime?
  signedAt    DateTime?
  canceledAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@map("patient_contracts")
}

// ---- ORÇAMENTOS CLÍNICOS ----

model ClinicalQuote {
  id          String      @id @default(cuid())
  companyId   String
  patientId   String
  title       String
  status      QuoteStatus @default(DRAFT)
  discount    Float       @default(0) // valor absoluto de desconto
  subtotal    Float       @default(0)
