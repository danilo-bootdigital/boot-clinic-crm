// Módulo de Follow-up e Automações
model FollowUpTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  content         String
  type            FollowUpType
  dueHours        Int      // Horas após o gatilho
  isRecurring     Boolean  @default(false)
  recurrenceType  RecurrenceType?
  recurrenceEvery Int?    // Dias/semanas/meses
  isActive        Boolean  @default(true)
  companyId       String
  clinicId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  clinic          Clinic  @relation(fields: [clinicId], references: [id])
  tasks           FollowUpTask[]

  @@unique([companyId, name])
  @@map("follow_up_templates")
}

model FollowUpTask {
  id              String   @id @default(cuid())
  title           String
  description     String?
  dueDate         DateTime
  status          TaskStatus @default(PENDING)
  priority        Priority @default(MEDIUM)
  type            TaskType
  templateId      String?
  assignedToId    String?
  createdById     String
  completedAt     DateTime?
  canceledAt      DateTime?
  canceledReason  String?
  companyId       String
  clinicId        String
  patientId       String?
  dealId          String?
  appointmentId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  clinic          Clinic  @relation(fields: [clinicId], references: [id])
  template        FollowUpTemplate? @relation(fields: [templateId], references: [id])
  assignedTo      User? @relation("UserAssignedTasks", fields: [assignedToId], references: [id])
  createdBy       User @relation("UserCreatedTasks", fields: [createdById], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  deal            Deal? @relation(fields: [dealId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  executions      AutomationExecution[]
  timelineEvents  PatientTimelineEvent[]

  @@map("follow_up_tasks")
}

model AutomationRule {
  id              String   @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean  @default(true)
  companyId       String
  clinicId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  clinic          Clinic  @relation(fields: [clinicId], references: [id])
  triggers        AutomationTrigger[]
  actions         AutomationAction[]
  executions      AutomationExecution[]

  @@unique([companyId, name])
  @@map("automation_rules")
}

model AutomationTrigger {
  id              String   @id @default(cuid())
  ruleId          String
  entityType      EntityType
  event           String   // Evento específico (paciente.criado, pipeline.movido, etc.)
  condition       String?  // Condição JSON para execução
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  rule            AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([companyId, ruleId, entityType, event])
  @@map("automation_triggers")
}

model AutomationAction {
  id              String   @id @default(cuid())
  ruleId          String
  actionType      ActionType
  config          String   // Configuração JSON da ação
  order           Int
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  rule            AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([companyId, ruleId, order])
  @@map("automation_actions")
}

model AutomationExecution {
  id              String   @id @default(cuid())
  ruleId          String
  triggerId       String
  status          ExecutionStatus @default(PENDING)
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  error           String?
  result          String?  // Resultado JSON
  companyId       String
  clinicId        String
  patientId       String?
  dealId          String?
  appointmentId   String?
  taskId          String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  clinic          Clinic  @relation(fields: [clinicId], references: [id])
  rule            AutomationRule @relation(fields: [ruleId], references: [id])
  trigger         AutomationTrigger @relation(fields: [triggerId], references: [id])
  task            FollowUpTask? @relation(fields: [taskId], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  deal            Deal? @relation(fields: [dealId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("automation_executions")
}

model NotificationEvent {
  id              String   @id @default(cuid())
  title           String
  message         String
  type            NotificationType
  priority        Priority @default(MEDIUM)
  isRead          Boolean  @default(false)
  userId          String
  companyId       String
  clinicId        String
  patientId       String?
  dealId          String?
  appointmentId   String?
  metadata        String?  // Dados adicionais JSON
  readAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  clinic          Clinic  @relation(fields: [clinicId], references: [id])
  user            User @relation(fields: [userId], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  deal            Deal? @relation(fields: [dealId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("notification_events")
}

// Enums
enum FollowUpType {
  MANUAL
  AUTOMATIC
  RECURRING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
  OVERDUE
}

enum TaskType {
  FOLLOW_UP
  REMINDER
  ALERT
  TASK
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum EntityType {
  PATIENT
  DEAL
  APPOINTMENT
  WHATSAPP_CONVERSATION
}

enum ActionType {
  CREATE_TASK
  CREATE_FOLLOW_UP
  MOVE_PIPELINE_STAGE
  SEND_NOTIFICATION
  SEND_WHATSAPP
  CREATE_TIMELINE_EVENT
  ASSIGN_USER
  UPDATE_STATUS
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}