generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Multiempresa
model Company {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?  @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@map("companies")
}

// Usuários e Autenticação
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  avatar      String?
  role        UserRole
  companyId   String
  clinicId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company     Company @relation(fields: [companyId], references: [id])

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  DOCTOR
  RECEPTION
  FINANCE
  MARKETING
  ATTENDANCE
}

// Módulo de Pacientes
model Patient {
  id          String   @id @default(cuid())
  name        String
  cpf         String   @unique
  birthDate   DateTime
  gender      Gender
  phone       String
  whatsapp    String?
  email       String?
  origin      PatientOrigin
  status      PatientStatus @default(ACTIVE)
  companyId   String
  clinicId    String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company     Company @relation(fields: [companyId], references: [id])
  createdBy   User    @relation(fields: [createdById], references: [id])

  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum PatientOrigin {
  GOOGLE
  FACEBOOK
  INSTAGRAM
  REFERRAL
  WALK_IN
  PHONE
  WHATSAPP
  OTHER
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// Módulo de CRM/Pipeline
model Deal {
  id               String   @id @default(cuid())
  title            String
  description      String?
  valueEstimated   Float?
  priority         Priority @default(MEDIUM)
  status           DealStatus @default(NEW)
  companyId        String
  clinicId         String
  patientId        String?
  responsibleUserId String
  nextFollowUpAt   DateTime?
  lastContactAt    DateTime?
  wonAt            DateTime?
  lostAt           DateTime?
  lossReasonId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  // Relacionamentos
  company          Company @relation(fields: [companyId], references: [id])
  patient          Patient? @relation(fields: [patientId], references: [id])
  responsibleUser  User    @relation(fields: [responsibleUserId], references: [id])

  @@map("deals")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DealStatus {
  NEW
  CONTACTED
  IN_NEGOTIATION
  APPOINTMENT_SCHEDULED
  APPOINTMENT_ATTENDED
  QUOTE_SENT
  WON
  LOST
}

// Módulo de Follow-up e Automações
model FollowUpTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  content         String
  type            FollowUpType
  dueHours        Int      // Horas após o gatilho
  isRecurring     Boolean  @default(false)
  recurrenceType  RecurrenceType?
  recurrenceEvery Int?    // Dias/semanas/meses
  isActive        Boolean  @default(true)
  companyId       String
  clinicId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("follow_up_templates")
}

model FollowUpTask {
  id              String   @id @default(cuid())
  title           String
  description     String?
  dueDate         DateTime
  status          TaskStatus @default(PENDING)
  priority        Priority @default(MEDIUM)
  type            TaskType
  templateId      String?
  assignedToId    String?
  createdById     String
  completedAt     DateTime?
  canceledAt      DateTime?
  canceledReason  String?
  companyId       String
  clinicId        String
  patientId       String?
  dealId          String?
  appointmentId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  template        FollowUpTemplate? @relation(fields: [templateId], references: [id])
  assignedTo      User? @relation("UserAssignedTasks", fields: [assignedToId], references: [id])
  createdBy       User @relation("UserCreatedTasks", fields: [createdById], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  deal            Deal? @relation(fields: [dealId], references: [id])

  @@map("follow_up_tasks")
}

model AutomationRule {
  id              String   @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean  @default(true)
  companyId       String
  clinicId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("automation_rules")
}

model AutomationTrigger {
  id              String   @id @default(cuid())
  ruleId          String
  entityType      EntityType
  event           String   // Evento específico (paciente.criado, pipeline.movido, etc.)
  condition       String?  // Condição JSON para execução
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  rule            AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([companyId, ruleId, entityType, event])
  @@map("automation_triggers")
}

model AutomationAction {
  id              String   @id @default(cuid())
  ruleId          String
  actionType      ActionType
  config          String   // Configuração JSON da ação
  order           Int
  companyId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  rule            AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([companyId, ruleId, order])
  @@map("automation_actions")
}

model AutomationExecution {
  id              String   @id @default(cuid())
  ruleId          String
  triggerId       String
  status          ExecutionStatus @default(PENDING)
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  error           String?
  result          String?  // Resultado JSON
  companyId       String
  clinicId        String
  patientId       String?
  dealId          String?
  taskId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  rule            AutomationRule @relation(fields: [ruleId], references: [id])
  trigger         AutomationTrigger @relation(fields: [triggerId], references: [id])
  task            FollowUpTask? @relation(fields: [taskId], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  deal            Deal? @relation(fields: [dealId], references: [id])

  @@map("automation_executions")
}

model NotificationEvent {
  id              String   @id @default(cuid())
  title           String
  message         String
  type            NotificationType
  priority        Priority @default(MEDIUM)
  isRead          Boolean  @default(false)
  userId          String
  companyId       String
  patientId       String?
  dealId          String?
  metadata        String?  // Dados adicionais JSON
  readAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relacionamentos
  company         Company @relation(fields: [companyId], references: [id])
  user            User @relation(fields: [userId], references: [id])
  patient         Patient? @relation(fields: [patientId], references: [id])
  deal            Deal? @relation(fields: [dealId], references: [id])

  @@map("notification_events")
}

// Módulo de Agenda Médica
model Appointment {
  id                  String   @id @default(cuid())
  patientId           String
  professionalId      String
  specialtyId        String
  roomId              String?
  type                String
  status              AppointmentStatus @default(PENDING)
  startAt             DateTime
  endAt               DateTime
  durationMinutes     Int
  source              String
  notes               String?
  createdById         String
  confirmedAt         DateTime?
  canceledAt          DateTime?
  cancellationReason  String?
  noShowAt            DateTime?
  attendedAt          DateTime?
  companyId           String
  clinicId            String
  dealId              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  // Relacionamentos
  patient             Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy           User @relation(fields: [createdById], references: [id])
  deal                Deal? @relation(fields: [dealId], references: [id])

  @@map("appointments")
}

model Specialty {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company     Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("specialties")
}

model Professional {
  id          String   @id @default(cuid())
  name        String
  crm         String?
  phone       String?
  email       String?
  companyId   String
  clinicId    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company     Company @relation(fields: [companyId], references: [id])

  @@map("professionals")
}

model ProfessionalSpecialty {
  id            String   @id @default(cuid())
  professionalId String
  specialtyId   String
  companyId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  professional  Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  specialty     Specialty    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  company       Company      @relation(fields: [companyId], references: [id])

  @@unique([professionalId, specialtyId])
  @@map("professional_specialties")
}

model Room {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String
  clinicId    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company     Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("rooms")
}

model AppointmentType {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int      // minutos
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  company     Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("appointment_types")
}

model ProfessionalSchedule {
  id          String   @id @default(cuid())
  professionalId String
  dayOfWeek   Int      // 0-6 (Domingo-Sábado)
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  isActive    Boolean  @default(true)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  company     Company @relation(fields: [companyId], references: [id])

  @@map("professional_schedules")
}

model ScheduleBlock {
  id          String   @id @default(cuid())
  professionalId String
  date        DateTime
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  reason      String?
  isRecurring Boolean  @default(false)
  recurringPattern String? // daily, weekly, monthly
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relacionamentos
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  company     Company @relation(fields: [companyId], references: [id])

  @@map("schedule_blocks")
}

model AppointmentStatusHistory {
  id            String   @id @default(cuid())
  appointmentId String
  status        AppointmentStatus
  notes         String?
  changedById   String
  createdAt     DateTime @default(now())

  // Relacionamentos
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedBy     User @relation(fields: [changedById], references: [id])

  @@map("appointment_status_history")
}

model AppointmentReminder {
  id            String   @id @default(cuid())
  appointmentId String
  type          ReminderType
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_reminders")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  RESCHEDULED
  ATTENDED
  NO_SHOW
}

enum ReminderType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

// Enums
enum FollowUpType {
  MANUAL
  AUTOMATIC
  RECURRING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
  OVERDUE
}

enum TaskType {
  FOLLOW_UP
  REMINDER
  ALERT
  TASK
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum EntityType {
  PATIENT
  DEAL
  APPOINTMENT
  WHATSAPP_CONVERSATION
}

enum ActionType {
  CREATE_TASK
  CREATE_FOLLOW_UP
  MOVE_PIPELINE_STAGE
  SEND_NOTIFICATION
  SEND_WHATSAPP
  CREATE_TIMELINE_EVENT
  ASSIGN_USER
  UPDATE_STATUS
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}