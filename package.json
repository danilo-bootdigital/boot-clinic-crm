{
  "name": "boot-clinic-crm-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:prod": "prisma migrate deploy && next start",
    "lint": "next lint",
    "lint:whatsapp": "next lint --dir src/lib/whatsapp --dir src/lib/storage --dir src/app/api/whatsapp --dir src/components/whatsapp --dir src/test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node --env-file=.env node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:push": "node --env-file=.env scripts/prisma-migrate.mjs db push",
    "db:migrate": "node --env-file=.env scripts/prisma-migrate.mjs migrate dev",
    "db:migrate:deploy": "node --env-file=.env scripts/prisma-migrate.mjs migrate deploy",
    "db:migrate:status": "node --env-file=.env scripts/prisma-migrate.mjs migrate status",
    "db:migrate:local": "node --env-file=.env scripts/prisma-migrate.mjs --local migrate dev",
    "db:migrate:prod": "ALLOW_PROD_MIGRATE=1 node --env-file=.env scripts/prisma-migrate.mjs migrate deploy",
    "db:studio": "prisma studio",
    "seed": "node --env-file=.env scripts/seed.mjs",
    "promote-super-admin": "node --env-file=.env scripts/promote-super-admin.mjs",
    "admin-smoke": "node --env-file=.env scripts/admin-smoke.mjs",
    "asaas-webhook-smoke": "node --env-file=.env scripts/asaas-webhook-smoke.mjs",
    "asaas-live-check": "node --env-file=.env scripts/asaas-live-check.mjs",
    "asaas-setup-webhook": "node --env-file=.env scripts/asaas-setup-webhook.mjs",
    "clinico-smoke": "node --env-file=.env scripts/clinico-smoke.mjs",
    "modular-smoke": "node --env-file=.env scripts/modular-smoke.mjs",
    "financial-smoke": "node --env-file=.env scripts/financial-smoke.mjs",
    "financial-payables-smoke": "node --env-file=.env scripts/financial-payables-smoke.mjs",
    "financial-rls-check": "node --env-file=.env scripts/financial-rls-check.mjs",
    "setup-app-role": "node --env-file=.env scripts/setup-app-role.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@prisma/client": "^5.6.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.2.16",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.292.0",
    "next": "14.0.4",
    "next-auth": "^4.24.5",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.48.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "postcss": "^8",
    "prisma": "^5.6.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
