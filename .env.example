# Database
# Copie este arquivo para .env e preencha com suas credenciais
#
# DUAS conexões (necessário para a RLS do módulo financeiro funcionar):
#  - DATABASE_URL  = role de RUNTIME do app. DEVE ser um role SEM BYPASSRLS
#    (ex.: app_user criado por `npm run setup-app-role`). Se for o `postgres`
#    (superuser, BYPASSRLS), a RLS FORCE é ignorada e NÃO isola por empresa.
#  - MIGRATE_DATABASE_URL = role privilegiado (postgres) usado SÓ por
#    `prisma migrate`/`db push` (precisa de DDL). O Prisma Client não o usa.
DATABASE_URL="postgresql://app_user:[APP_USER_PASSWORD]@db.zjhapezbcqoqwrwolcju.supabase.co:5432/postgres?schema=boot_clinic_crm"
MIGRATE_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.zjhapezbcqoqwrwolcju.supabase.co:5432/postgres?schema=boot_clinic_crm"

# Supabase
