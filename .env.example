# Service role key (somente para o seed local — NUNCA expor no client). Em: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=""

# Asaas (cobrança recorrente das assinaturas das clínicas) — SOMENTE no servidor.
# API key em: Asaas → Integrações → API → Gerar/Copiar chave. (Produção começa com $aact_prod_...)
ASAAS_API_KEY=""
# Base da API. Produção (padrão): https://api.asaas.com/v3 — Sandbox: https://api-sandbox.asaas.com/v3
ASAAS_API_URL="https://api.asaas.com/v3"
# Token do webhook: defina o MESMO valor aqui e em Asaas → Integrações → Webhooks (Token de autenticação).
ASAAS_WEBHOOK_TOKEN=""
# Opcionais (sobrescrevem o catálogo de planos):
# ASAAS_PLAN_BASIC=197
# ASAAS_PLAN_PRO=397
# ASAAS_TRIAL_DAYS=14

# Telemedicina — provider de vídeo agnóstico (padrão: Jitsi por URL, sem custo).
# Base pública do app (para montar o link enviado ao paciente por WhatsApp).
NEXT_PUBLIC_APP_URL="https://app.seudominio.com.br"
