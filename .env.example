# Database
# Copie este arquivo para .env e preencha com suas credenciais
#
# DUAS conexões (necessário para a RLS do módulo financeiro funcionar):
#  - DATABASE_URL  = role de RUNTIME do app. DEVE ser um role SEM BYPASSRLS
#    (ex.: app_user criado por `npm run setup-app-role`). Se for o `postgres`
#    (superuser, BYPASSRLS), a RLS FORCE é ignorada e NÃO isola por empresa.
#  - MIGRATE_DATABASE_URL = role privilegiado (postgres) usado SÓ por
#    `prisma migrate`/`db push` (precisa de DDL). O Prisma Client não o usa.
#
# ⚠️  MIGRATE_DATABASE_URL abaixo aponta para PRODUÇÃO. Um `prisma migrate
#     deploy/dev/reset` escreve DIRETO em produção. Por isso os scripts
#     `db:migrate*` passam pelo guard `scripts/prisma-migrate.mjs`, que BLOQUEIA
#     migrations mutantes contra host remoto sem opt-in explícito. NUNCA rode
#     `npx prisma migrate ...` cru — use os npm scripts:
#       npm run db:migrate:local              # testa em LOCAL_DATABASE_URL
#       npm run db:migrate:status             # só leitura
#       npm run db:migrate:prod               # intencional: aplica em produção
DATABASE_URL="postgresql://app_user:[APP_USER_PASSWORD]@db.medgsepwjflkxuqbkyjx.supabase.co:5432/postgres?schema=boot_clinic_crm"
MIGRATE_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.medgsepwjflkxuqbkyjx.supabase.co:5432/postgres?schema=boot_clinic_crm"
# Banco de desenvolvimento descartável para testar migrations com segurança
# (usado por `npm run db:migrate:local`). Suba com:
#   docker run -d --name bootclinic-localdb -e POSTGRES_PASSWORD=test -e POSTGRES_DB=bootclinic -p 55433:5432 postgres:15
LOCAL_DATABASE_URL="postgresql://postgres:test@localhost:55433/bootclinic?schema=public"

# Supabase (projeto oficial do Boot Clinic CRM)
NEXT_PUBLIC_SUPABASE_URL="https://medgsepwjflkxuqbkyjx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_dGV_XtpmnYviA1mtpfN_zw_k28bYsie"
# Service role key (somente para o seed local — NUNCA expor no client). Em: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=""

# Asaas (cobrança recorrente das assinaturas das clínicas) — SOMENTE no servidor.
# API key em: Asaas → Integrações → API → Gerar/Copiar chave. (Produção começa com $aact_prod_...)
ASAAS_API_KEY=""
# Base da API. Produção (padrão): https://api.asaas.com/v3 — Sandbox: https://api-sandbox.asaas.com/v3
ASAAS_API_URL="https://api.asaas.com/v3"
# Token do webhook: defina o MESMO valor aqui e em Asaas → Integrações → Webhooks (Token de autenticação).
ASAAS_WEBHOOK_TOKEN=""
# Opcionais (sobrescrevem o catálogo de planos):
# ASAAS_PLAN_BASIC=197
# ASAAS_PLAN_PRO=397
# ASAAS_TRIAL_DAYS=14

# Telemedicina — provider de vídeo agnóstico (padrão: Jitsi por URL, sem custo).
# Base pública do app (para montar o link enviado ao paciente por WhatsApp).
NEXT_PUBLIC_APP_URL="https://app.seudominio.com.br"
# TELEMEDICINE_PROVIDER="JITSI"
# TELEMEDICINE_JITSI_BASE="https://meet.jit.si"   # ou seu self-host

# WhatsApp (Evolution API) — usado para enviar link/lembretes da teleconsulta.
# Se não configurado, as mensagens ficam registradas na timeline (pronto-para-conectar).
# WHATSAPP_API_URL=""
# WHATSAPP_API_KEY=""
# WHATSAPP_INSTANCE=""